# ─── Environment ────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=INFO
TZ=UTC

# ─── Backend (FastAPI) ──────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=2
BACKEND_PUBLIC_URL=http://localhost:8000
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ─── Database (PostgreSQL) ──────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sentineleye
POSTGRES_USER=sentineleye
POSTGRES_PASSWORD=sentineleye
DATABASE_URL=postgresql+asyncpg://sentineleye:sentineleye@postgres:5432/sentineleye

# ─── Redis (cache, queues, pubsub) ──────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Storage ────────────────────────────────────────────────────────
STORAGE_MODE=hybrid              # local | s3 | hybrid
LOCAL_STORAGE_PATH=/data/recordings
RETENTION_DAYS=14
ARCHIVE_AFTER_DAYS=2             # local → S3 after N days (hybrid)

# ─── S3 / MinIO ─────────────────────────────────────────────────────
S3_ENDPOINT_URL=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=sentineleye-recordings
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false
S3_SIGNED_URL_TTL=3600

# ─── AI Engine ──────────────────────────────────────────────────────
AI_ENGINE_HOST=0.0.0.0
AI_ENGINE_PORT=8100
YOLO_MODEL=yolov8n.pt            # yolov8n/s/m/l/x, yolov9, yolov10, yolo11
YOLO_DEVICE=auto                 # auto | cpu | cuda:0
YOLO_CONFIDENCE=0.45
YOLO_IOU=0.50
YOLO_IMG_SIZE=640
TRACKER=bytetrack                # bytetrack | deepsort
ENABLE_GPU=false                 # set true if CUDA is available

# ─── Recording Service ──────────────────────────────────────────────
RECORDING_SEGMENT_SECONDS=300
RECORDING_FORMAT=mp4
RECORDING_VIDEO_CODEC=libx264
RECORDING_AUDIO_CODEC=aac
RECORDING_PRESET=veryfast

# ─── Notifications ──────────────────────────────────────────────────
NOTIFY_EMAIL_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@sentineleye.local

NOTIFY_TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

NOTIFY_WEBHOOK_ENABLED=true

# ─── Observability ──────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
SENTRY_DSN=

# ─── Env / secrets ──────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ─── Python ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
ENV/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.hypothesis/

# ─── Flutter / Dart ─────────────────────────────────────────────────
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
*.iml
*.ipr
*.iws
.idea/
.vscode/
android/.gradle/
android/local.properties
ios/Flutter/Generated.xcconfig
ios/Runner/GeneratedPluginRegistrant.*

# ─── Models & data ──────────────────────────────────────────────────
models/*.pt
models/*.onnx
models/*.engine
data/
recordings/
snapshots/
*.mp4
*.mkv
*.avi
*.mov
!docs/**/*.mp4

# ─── Logs ───────────────────────────────────────────────────────────
*.log
logs/

# ─── OS ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Docker volumes (when bind-mounted locally) ─────────────────────
.docker-data/
postgres-data/
redis-data/
minio-data/

# ─── Build / tooling caches ─────────────────────────────────────────
# .cache/ is used by scripts/build/build-android.sh for the persistent
# Gradle cache (multi-GB). Never commit it.
.cache/
.gradle/
**/.gradle/
.cxx/
.kotlin/

# ─── Test / coverage artifacts ──────────────────────────────────────
coverage/
coverage.xml
.coverage.*
junit.xml
pytest-report.xml

# ─── Native build outputs that escape dist/ ─────────────────────────
# Most artifacts go through dist/ (already ignored above) but loose
# binaries from ad-hoc builds shouldn't sneak in.
*.apk
*.aab
*.ipa
*.dmg
*.deb
*.rpm
*.AppImage
*.msi
*.exe
*.app/

# ─── Editor / OS extras (catch what other sections missed) ──────────
*~
*.swp
*.swo
*.bak
*.tmp
._*
.AppleDouble
.LSOverride
Icon?
$RECYCLE.BIN/
*.lnk

# ─── Scratch directories ────────────────────────────────────────────
tmp/
temp/
scratch/

# ─── Node (if any tooling shows up) ─────────────────────────────────
node_modules/
